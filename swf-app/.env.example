# Server-side proxy (Next route → swf-api). Default: http://127.0.0.1:3200
SWF_API_URL=http://127.0.0.1:3200

# Optional: browser calls swf-api directly (skips Next proxy = usually faster).
# Must match a URL swf-api CORS allows. Same value as SWF_API_URL is typical.
# NEXT_PUBLIC_SWF_API_URL=http://127.0.0.1:3200
